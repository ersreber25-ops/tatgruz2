---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';
interface Props {
  lang: Lang;
  currentPath?: string;
}
const { lang, currentPath = '/' } = Astro.props;
const base = lang === 'tt' ? '/tt' : '';
const ruHref = lang === 'ru' ? currentPath : currentPath.replace('/tt', '') || '/';
const ttHref = lang === 'tt' ? currentPath : '/tt' + currentPath;
const navLinks = [
  { key: 'nav_home', href: base + '/', icon: 'home' },
  { key: 'nav_services', href: base + '/#services', icon: 'local_shipping' },
  { key: 'nav_map', href: base + '/#map', icon: 'map' },
  { key: 'nav_about', href: base + '/#why', icon: 'verified' },
  { key: 'nav_blog', href: base + '/blog', icon: 'article' },
  { key: 'nav_contacts', href: base + '/#contacts', icon: 'call' },
] as const;
---
<header class="site-header" id="site-header" role="banner">
  <div class="header-inner container">
    <a href={base + '/'} class="header-logo" aria-label="Автопарк Лузянина - на главную">
      <div class="logo-mark">
        <img
          src="/images/logo.png"
          alt="Логотип Автопарк Лузянина"
          width="36"
          height="36"
          class="logo-img"
          loading="eager"
        />
      </div>
      <div class="logo-text">
        <span class="logo-name">Автопарк</span>
        <span class="logo-surname">Лузянина</span>
      </div>
    </a>
    <nav class="header-nav" aria-label="Основная навигация">
      <ul class="nav-list" role="list">
        {navLinks.map(({ key, href, icon }) => (
          <li>
            <a
              href={href}
              class="nav-link"
              aria-current={currentPath === href ? 'page' : undefined}
            >
              <span class="material-symbols-outlined nav-icon" aria-hidden="true">{icon}</span>
              <span>{t(lang, key as any)}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="header-controls">
      <div class="lang-toggle" role="group" aria-label="Выбор языка">
        <a
          href={ruHref}
          class={`lang-btn ${lang === 'ru' ? 'active' : ''}`}
          aria-pressed={lang === 'ru'}
          hreflang="ru"
        >РУС</a>
        <a
          href={ttHref}
          class={`lang-btn ${lang === 'tt' ? 'active' : ''}`}
          aria-pressed={lang === 'tt'}
          hreflang="tt"
        >ТАТ</a>
      </div>
      <button
        id="theme-toggle"
        class="icon-btn"
        aria-label="Переключить тему"
        title="Переключить тему"
      >
        <span class="material-symbols-outlined theme-icon-light" aria-hidden="true">light_mode</span>
        <span class="material-symbols-outlined theme-icon-dark" aria-hidden="true">dark_mode</span>
      </button>
      <a
        href="tel:+78432000000"
        class="header-cta btn-primary"
        aria-label="Позвонить в Автопарк Лузянина"
      >
        <span class="material-symbols-outlined" aria-hidden="true">call</span>
        <span class="cta-text">{t(lang, 'nav_call')}</span>
      </a>
      <button
        class="burger"
        id="burger-btn"
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
    </div>
  </div>
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Мобильное меню">
    <nav aria-label="Мобильная навигация">
      <ul class="mobile-nav-list" role="list">
        {navLinks.map(({ key, href, icon }) => (
          <li>
            <a href={href} class="mobile-nav-link" onclick="closeMobileMenu()">
              <span class="material-symbols-outlined" aria-hidden="true">{icon}</span>
              <span>{t(lang, key as any)}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mobile-menu-tools">
      <div class="lang-toggle lang-toggle--mobile" role="group" aria-label="Выбор языка">
        <a
          href={ruHref}
          class={`lang-btn ${lang === 'ru' ? 'active' : ''}`}
          aria-pressed={lang === 'ru'}
          hreflang="ru"
        >РУС</a>
        <a
          href={ttHref}
          class={`lang-btn ${lang === 'tt' ? 'active' : ''}`}
          aria-pressed={lang === 'tt'}
          hreflang="tt"
        >ТАТ</a>
      </div>
      <button
        class="icon-btn mobile-theme-btn"
        onclick="document.getElementById('theme-toggle')?.click()"
        aria-label="Переключить тему"
        title="Переключить тему"
      >
        <span class="material-symbols-outlined theme-icon-light" aria-hidden="true">light_mode</span>
        <span class="material-symbols-outlined theme-icon-dark" aria-hidden="true">dark_mode</span>
      </button>
    </div>
    <div class="mobile-menu-footer">
      <a href="tel:+78432000000" class="btn-primary mobile-call-btn">
        <span class="material-symbols-outlined" aria-hidden="true">call</span>
        {t(lang, 'nav_call')}
      </a>
      <a href="mailto:info@autoluz.ru" class="btn-secondary mobile-mail-btn">
        <span class="material-symbols-outlined" aria-hidden="true">mail</span>
        Email
      </a>
    </div>
  </div>
  <div class="mobile-overlay" id="mobile-overlay" onclick="closeMobileMenu()"></div>
</header>
<script is:inline>
  const themeBtn = document.getElementById('theme-toggle');
  function applyTheme(theme) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }
  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });
  }
  const burger = document.getElementById('burger-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileOverlay = document.getElementById('mobile-overlay');
  const header = document.getElementById('site-header');
  function openMobileMenu() {
    if (!mobileMenu || !mobileOverlay || !burger) return;
    mobileMenu.setAttribute('aria-hidden', 'false');
    mobileMenu.classList.add('open');
    mobileOverlay.classList.add('visible');
    burger.setAttribute('aria-expanded', 'true');
    burger.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeMobileMenu() {
    if (!mobileMenu || !mobileOverlay || !burger) return;
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileMenu.classList.remove('open');
    mobileOverlay.classList.remove('visible');
    burger.setAttribute('aria-expanded', 'false');
    burger.classList.remove('active');
    document.body.style.overflow = '';
  }
  if (burger) {
    burger.addEventListener('click', () => {
      const isOpen = burger.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMobileMenu() : openMobileMenu();
    });
  }
  window.addEventListener('scroll', () => {
    if (!header) return;
    if (window.scrollY > 80) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  }, { passive: true });
  window.addEventListener('resize', () => {
    if (window.innerWidth > 860) {
      closeMobileMenu();
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMobileMenu();
  });
</script>
<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }
  .site-header.scrolled {
    background: var(--bg-glass);
    backdrop-filter: var(--blur-glass);
    -webkit-backdrop-filter: var(--blur-glass);
    box-shadow: 0 1px 0 var(--border), var(--shadow-md);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 76px;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .header-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
    min-width: 0;
  }
  .logo-mark {
    transition: transform var(--transition);
  }
  .header-logo:hover .logo-mark {
    transform: rotate(-5deg) scale(1.05);
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    min-width: 0;
  }
  .logo-name {
    font-size: 0.72rem;
    font-weight: var(--font-regular);
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .logo-surname {
    font-size: 1.05rem;
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }
  .header-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: var(--font-regular);
    color: var(--text-secondary);
    transition: color var(--transition-fast), background var(--transition-fast);
    white-space: nowrap;
  }
  .nav-icon {
    font-size: 1.1rem;
    opacity: 0.6;
    transition: opacity var(--transition-fast);
  }
  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-dark-card);
  }
  .nav-link:hover .nav-icon {
    opacity: 1;
  }
  .nav-link[aria-current='page'] {
    color: var(--accent);
    background: rgba(26, 86, 219, 0.1);
    font-weight: var(--font-semibold);
  }
  .nav-link[aria-current='page'] .nav-icon {
    opacity: 1;
  }
  .header-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    margin-left: auto;
  }
  .lang-toggle {
    display: flex;
    background: var(--bg-dark-card);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 3px;
    gap: 2px;
  }
  .lang-btn {
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .lang-btn.active {
    background: var(--accent);
    color: white;
    box-shadow: 0 2px 8px var(--accent-glow);
  }
  .lang-btn:not(.active):hover {
    color: var(--text-primary);
    background: var(--border);
  }
  .icon-btn {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-dark-card);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    position: relative;
  }
  .icon-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-strong);
    background: var(--border);
  }
  .theme-icon-dark {
    display: none;
  }
  [data-theme='dark'] .theme-icon-light {
    display: none;
  }
  [data-theme='dark'] .theme-icon-dark {
    display: block;
  }
  .header-cta {
    padding: 9px 18px !important;
    font-size: 0.88rem !important;
    gap: 8px;
    flex-shrink: 0;
  }
  .cta-text {
    white-space: nowrap;
  }
  .burger {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    width: 42px;
    height: 42px;
    padding: 0;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-dark-card);
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }
  .burger:hover {
    background: var(--bg-card);
    border-color: var(--border-strong);
  }
  .burger.active {
    transform: scale(0.98);
  }
  .burger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    transform-origin: center;
  }
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 998;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .mobile-overlay.visible {
    display: block;
    opacity: 1;
  }
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    right: -100%;
    bottom: 0;
    width: min(360px, 100vw);
    background: var(--bg-glass-strong);
    backdrop-filter: var(--blur-glass);
    -webkit-backdrop-filter: var(--blur-glass);
    border-left: 1px solid var(--border);
    z-index: 999;
    flex-direction: column;
    padding: 88px 20px 24px;
    transition: right 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    overflow-y: auto;
  }
  .mobile-menu.open {
    right: 0;
  }
  .mobile-nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 14px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 0.98rem;
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .mobile-nav-link .material-symbols-outlined {
    color: var(--accent);
    font-size: 1.3rem;
  }
  .mobile-nav-link:hover {
    background: rgba(26, 86, 219, 0.1);
    color: var(--accent);
  }
  .mobile-menu-tools {
    display: none;
  }
  .lang-toggle--mobile {
    width: 100%;
    justify-content: center;
  }
  .mobile-theme-btn {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
  }
  .mobile-menu-footer {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    margin-top: 20px;
  }
  .mobile-call-btn,
  .mobile-mail-btn {
    justify-content: center;
    width: 100%;
  }
  .logo-img {
    border-radius: 10px;
    object-fit: contain;
    transition: transform var(--transition);
  }
  .header-logo:hover .logo-img {
    transform: rotate(-5deg) scale(1.05);
  }
  @media (max-width: 1024px) {
    .nav-link span:not(.nav-icon) {
      display: none;
    }
    .nav-link {
      padding: 8px 10px;
    }
  }
  @media (max-width: 860px) {
    .header-nav {
      display: none;
    }
    .burger,
    .mobile-menu {
      display: flex;
    }
    .header-controls .lang-toggle,
    .header-controls .icon-btn {
      display: none;
    }
    .header-inner {
      gap: 10px;
      min-height: 72px;
      padding-top: 12px;
      padding-bottom: 12px;
      padding-left: 16px;
      padding-right: 16px;
    }
    .header-cta {
      width: 42px;
      height: 42px;
      padding: 0 !important;
      justify-content: center;
      border-radius: 12px;
      font-size: 0;
    }
    .header-cta .cta-text {
      display: none;
    }
    .header-cta .material-symbols-outlined {
      font-size: 1.15rem;
    }
    .mobile-menu-tools {
      display: flex;
      align-items: center;
      gap: 12px;
      margin: 18px 0 4px;
    }
    .logo-name {
      font-size: 0.65rem;
    }
    .logo-surname {
      font-size: 0.95rem;
    }
  }
  @media (max-width: 600px) {
    .header-inner {
      gap: 8px;
      min-height: 68px;
    }
    .logo-text {
      max-width: 150px;
    }
    .logo-name {
      font-size: 0.62rem;
    }
    .logo-surname {
      font-size: 0.9rem;
    }
    .logo-img {
      width: 32px;
      height: 32px;
    }
  }
  @media (max-width: 420px) {
    .logo-name {
      display: none;
    }
    .logo-surname {
      font-size: 0.86rem;
      line-height: 1;
    }
    .mobile-menu {
      padding-left: 16px;
      padding-right: 16px;
    }
  }
</style>
