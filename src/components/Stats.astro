---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const reasons = [
  { key: 'why_1', icon: 'ads_click', color: '#1a56db' },
  { key: 'why_2', icon: 'gavel',     color: '#7c3aed' },
  { key: 'why_3', icon: 'health_and_safety', color: '#059669' },
  { key: 'why_4', icon: 'price_check', color: '#d97706' },
  { key: 'why_5', icon: 'gps_fixed',  color: '#0891b2' },
  { key: 'why_6', icon: 'shield_lock', color: '#dc2626' },
] as const;
const metrics = [
  { value: '98%', label: 'Вовремя', icon: 'timer' },
  { value: '5+', label: 'Лет опыта', icon: 'workspace_premium' },
  { value: '1300+', label: 'Рейсов', icon: 'route' },
  { value: '24+', label: 'Доступность', icon: 'headset_mic' },
] as const;
---
<section class="section stats-section" id="why" aria-labelledby="why-heading">
  <div class="container">
    <div class="stats-top">
      <div class="stats-header" data-reveal="left">
        <div class="chip chip-accent section-chip">
          <span class="material-symbols-outlined" aria-hidden="true">verified</span>
          {t(lang, 'why_chip')}
        </div>
        <h2 class="heading-lg stats-title" id="why-heading">
          {t(lang, 'why_title').split('\n').map((line: string, i: number) => (
            <span>
              {i === 0 ? line : <><br /><span class="text-accent">{line}</span></>}
            </span>
          ))}
        </h2>
        <p class="stats-intro-text">
          Мы не обещаем - мы показываем цифры. Каждая из них выстрадана годами работы на дороге.
        </p>
        <a href="tel:+78432000000" class="btn-primary stats-cta" aria-label="Позвонить в Автопарк Лузянина">
          <span class="material-symbols-outlined icon-filled" aria-hidden="true">call</span>
          Убедиться лично
        </a>
      </div>
      <div class="metrics-grid" data-reveal="right" data-delay="1">
        {metrics.map((m, i) => (
          <div
            class="metric-card glass"
            data-reveal="scale"
            data-delay={String(i + 1)}
          >
            <div class="metric-icon-row">
              <span class="material-symbols-outlined metric-icon icon-filled" aria-hidden="true">{m.icon}</span>
            </div>
            <div class="metric-value">{m.value}</div>
            <div class="metric-label">{m.label}</div>
            <div class="metric-bar">
              <div class="metric-bar-fill" style={`width: ${i === 3 ? 100 : 70 + i * 9}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="reasons-wrap">
      <div class="reasons-col">
        {reasons.slice(0, 3).map((r, i) => (
          <div
            class="reason-item"
            data-reveal="left"
            data-delay={String(i + 1)}
            style={`--r-color: ${r.color};`}
          >
            <div class="reason-icon-wrap">
              <span class="material-symbols-outlined reason-icon icon-filled" aria-hidden="true">{r.icon}</span>
            </div>
            <div class="reason-body">
              <h3 class="reason-title">{t(lang, `${r.key}_title` as any)}</h3>
              <p class="reason-desc">{t(lang, `${r.key}_desc` as any)}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="reasons-center" aria-hidden="true" data-reveal="scale" data-delay="2">
        <div class="road-visual">
          <div class="road-center-glow"></div>
          <img
            src="/images/sprinter-side.png"
            alt=""
            class="reasons-truck"
            width="340"
            height="180"
            loading="lazy"
          />
          <div class="road-line"></div>
          <div class="route-dots">
            <div class="route-dot dot-kazn">
              <div class="dot-pulse"></div>
              <span class="dot-label">Казань</span>
            </div>
            <div class="route-dot dot-msk">
              <div class="dot-pulse"></div>
              <span class="dot-label">Москва</span>
            </div>
            <div class="route-dot dot-spb">
              <div class="dot-pulse"></div>
              <span class="dot-label">СПб</span>
            </div>
          </div>
        </div>
      </div>
      <div class="reasons-col reasons-col--right">
        {reasons.slice(3).map((r, i) => (
          <div
            class="reason-item reason-item--right"
            data-reveal="right"
            data-delay={String(i + 1)}
            style={`--r-color: ${r.color};`}
          >
            <div class="reason-icon-wrap">
              <span class="material-symbols-outlined reason-icon icon-filled" aria-hidden="true">{r.icon}</span>
            </div>
            <div class="reason-body">
              <h3 class="reason-title">{t(lang, `${r.key}_title` as any)}</h3>
              <p class="reason-desc">{t(lang, `${r.key}_desc` as any)}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
<style>
  .stats-section {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }
  .stats-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gradient-accent);
    opacity: 0.3;
  }
  .stats-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 80px;
  }
  .section-chip { margin-bottom: 20px; }
  .stats-title {
    margin-bottom: 16px;
    white-space: pre-line;
  }
  .stats-intro-text {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 400px;
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .metric-card {
    padding: 24px 20px;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .metric-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gradient-accent);
    opacity: 0;
    transition: opacity var(--transition);
    border-radius: inherit;
  }
  .metric-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .metric-card:hover::before { opacity: 0.05; }
  .metric-icon-row {
    display: flex;
    align-items: center;
    margin-bottom: 4px;
  }
  .metric-icon {
    font-size: 1.4rem;
    color: var(--accent);
  }
  .metric-value {
    font-size: 2.2rem;
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    letter-spacing: -0.03em;
    line-height: 1;
    position: relative;
    z-index: 1;
  }
  .metric-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: var(--font-semibold);
    position: relative;
    z-index: 1;
  }
  .metric-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 8px;
  }
  .metric-bar-fill {
    height: 100%;
    background: var(--gradient-accent);
    border-radius: 2px;
    transition: width 1.5s cubic-bezier(0.23,1,0.32,1);
  }
  .reasons-wrap {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: center;
  }
  .reasons-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .reason-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 20px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    cursor: default;
  }
  .reason-item:hover {
    transform: translateX(6px);
    border-color: var(--r-color, var(--accent));
    box-shadow: -4px 0 0 var(--r-color, var(--accent)), var(--shadow-sm);
  }
  .reason-item--right:hover {
    transform: translateX(-6px);
    box-shadow: 4px 0 0 var(--r-color, var(--accent)), var(--shadow-sm);
  }
  .reason-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--r-color, #1a56db) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform var(--transition);
  }
  .reason-item:hover .reason-icon-wrap {
    transform: rotate(-8deg) scale(1.1);
  }
  .reason-icon {
    font-size: 1.3rem;
    color: var(--r-color, var(--accent));
  }
  .reason-title {
    font-size: 0.95rem;
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .reason-desc {
    font-size: 0.83rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .reasons-center {
    width: 280px;
    flex-shrink: 0;
  }
  .road-visual {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 20px 0;
  }
  .road-center-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .reasons-truck {
    width: 100%;
    max-width: 240px;
    height: auto;
    filter: drop-shadow(0 10px 30px rgba(0,0,0,0.3));
    animation: reasons-truck-float 4s ease-in-out infinite;
    position: relative;
    z-index: 2;
  }
  @keyframes reasons-truck-float {
    0%, 100% { transform: translateY(0) translateX(0); }
    25% { transform: translateY(-6px) translateX(4px); }
    75% { transform: translateY(4px) translateX(-4px); }
  }
  .road-line {
    width: 2px;
    height: 120px;
    background: linear-gradient(to bottom, var(--accent) 0%, transparent 100%);
    margin: 0 auto;
    position: relative;
  }
  .road-line::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
  }
  .route-dots {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }
  .route-dot {
    display: flex;
    align-items: center;
    gap: 10px;
    position: relative;
  }
  .dot-pulse {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-glow);
    animation: dot-pulse 2s ease infinite;
    flex-shrink: 0;
  }
  @keyframes dot-pulse {
    0% { box-shadow: 0 0 0 0 rgba(26,86,219,0.5); }
    70% { box-shadow: 0 0 0 10px rgba(26,86,219,0); }
    100% { box-shadow: 0 0 0 0 rgba(26,86,219,0); }
  }
  .dot-label {
    font-size: 0.78rem;
    font-weight: var(--font-semibold);
    color: var(--text-muted);
  }
  @media (max-width: 1100px) {
    .stats-top { gap: 40px; }
    .reasons-center { width: 220px; }
    .reasons-truck { max-width: 180px; }
  }
  @media (max-width: 860px) {
    .stats-top {
      grid-template-columns: 1fr;
      margin-bottom: 48px;
    }
    .stats-intro-text { max-width: 100%; }
    .metrics-grid { grid-template-columns: repeat(4, 1fr); }
    .metric-value { font-size: 1.6rem; }
    .reasons-wrap {
      grid-template-columns: 1fr;
    }
    .reasons-center { display: none; }
    .reasons-col, .reasons-col--right {
      gap: 12px;
    }
    .reason-item:hover { transform: translateX(4px); }
    .reason-item--right:hover { transform: translateX(4px); }
  }
  @media (max-width: 600px) {
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-cta { width: 100%; justify-content: center; }
  }
  @media (max-width: 400px) {
    .metric-value { font-size: 1.4rem; }
  }
</style>