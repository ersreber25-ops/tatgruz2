---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';
import { getCollection } from 'astro:content';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
const featured = sorted.filter(p => p.data.featured).slice(0, 1)[0];
const rest = sorted.filter(p => !p.data.featured || p.slug !== featured?.slug).slice(0, 5);
function formatDate(d: Date) {
  return new Intl.DateTimeFormat(lang === 'tt' ? 'ru-RU' : 'ru-RU', {
    day: 'numeric', month: 'long', year: 'numeric'
  }).format(d);
}
const base = lang === 'tt' ? '/tt' : '';
---
<section class="section blog-section" id="blog" aria-labelledby="blog-heading">
  <div class="container">
    <div class="blog-header" data-reveal>
      <div>
        <div class="chip chip-accent section-chip">
          <span class="material-symbols-outlined" aria-hidden="true">article</span>
          {t(lang, 'blog_chip')}
        </div>
        <h2 class="heading-lg" id="blog-heading">
          {t(lang, 'blog_title')}
        </h2>
        <p class="blog-subtitle" data-reveal data-delay="1">
          {t(lang, 'blog_subtitle')}
        </p>
      </div>
      <a href={`${base}/blog`} class="btn-secondary blog-all-btn" data-reveal="right" data-delay="2">
        <span class="material-symbols-outlined" aria-hidden="true">grid_view</span>
        {t(lang, 'blog_all')}
      </a>
    </div>
    <div class="blog-layout">
      {featured && (
        <article class="blog-featured glass" data-reveal="left" data-delay="1">
          <a href={`${base}/blog/${featured.slug}`} class="featured-img-wrap" aria-hidden="true" tabindex="-1">
            <div class="featured-img-placeholder">
              <img
                src={featured.data.image.endsWith('.jpg') ? '/images/blog/placeholder.svg' : featured.data.image}
                alt={lang === 'tt' ? featured.data.titleTt : featured.data.title}
                class="featured-img"
                width="800"
                height="450"
                loading="lazy"
              />
              <div class="featured-img-overlay"></div>
              <div class="featured-badge">
                <span class="material-symbols-outlined" aria-hidden="true">star</span>
                Главная статья
              </div>
            </div>
          </a>
          <div class="featured-body">
            <div class="featured-meta">
              <span class="chip chip-accent blog-cat">
                {lang === 'tt' ? featured.data.categoryTt : featured.data.category}
              </span>
              <span class="blog-date">
                <span class="material-symbols-outlined" aria-hidden="true">calendar_today</span>
                {formatDate(featured.data.pubDate)}
              </span>
              <span class="blog-read">
                <span class="material-symbols-outlined" aria-hidden="true">schedule</span>
                {featured.data.readTime} мин
              </span>
            </div>
            <h3 class="featured-title heading-md">
              <a href={`${base}/blog/${featured.slug}`}>
                {lang === 'tt' ? featured.data.titleTt : featured.data.title}
              </a>
            </h3>
            <p class="featured-desc">
              {lang === 'tt' ? featured.data.descriptionTt : featured.data.description}
            </p>
            <a href={`${base}/blog/${featured.slug}`} class="btn-primary featured-cta">
              <span class="material-symbols-outlined" aria-hidden="true">menu_book</span>
              {t(lang, 'blog_read_more')}
              <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </article>
      )}
      <div class="blog-list" role="list">
        {rest.map((post, i) => (
          <article
            class="blog-card glass"
            role="listitem"
            data-reveal="right"
            data-delay={String(i % 3 + 1)}
          >
            <a href={`${base}/blog/${post.id}`} class="blog-card-img-wrap" aria-hidden="true" tabindex="-1">
              <img
                src="/images/blog/placeholder.svg"
                alt=""
                class="blog-card-img"
                width="400"
                height="200"
                loading="lazy"
              />
              <div class="blog-card-img-overlay"></div>
            </a>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="chip chip-accent blog-cat-sm">
                  {lang === 'tt' ? post.data.categoryTt : post.data.category}
                </span>
                <span class="blog-read-sm">
                  <span class="material-symbols-outlined" aria-hidden="true">schedule</span>
                  {post.data.readTime} мин
                </span>
              </div>
              <h3 class="blog-card-title">
                <a href={`${base}/blog/${post.id}`}>
                  {lang === 'tt' ? post.data.titleTt : post.data.title}
                </a>
              </h3>
              <p class="blog-card-desc">
                {lang === 'tt' ? post.data.descriptionTt : post.data.description}
              </p>
              <div class="blog-card-footer">
                <span class="blog-date-sm">
                  <span class="material-symbols-outlined" aria-hidden="true">calendar_today</span>
                  {formatDate(post.data.pubDate)}
                </span>
                <a href={`${base}/blog/${post.id}`} class="blog-read-link" aria-label={`Читать: ${lang === 'tt' ? post.data.titleTt : post.data.title}`}>
                  {t(lang, 'blog_read_more')}
                  <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                </a>
              </div>
            </div>
          </article>
        ))}
        <a href={`${base}/blog`} class="blog-card blog-card--all glass" data-reveal="right" data-delay="3" aria-label="Посмотреть все статьи блога">
          <span class="material-symbols-outlined all-icon" aria-hidden="true">library_books</span>
          <span class="all-text">Все {allPosts.length} статей</span>
          <span class="material-symbols-outlined all-arrow" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>
</section>
<style>
  .blog-section {
    background: var(--gradient-section);
    position: relative;
    overflow: hidden;
  }
  .blog-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: var(--gradient-accent);
    opacity: 0.2;
  }
  .blog-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .section-chip { margin-bottom: 16px; }
  .blog-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-top: 12px;
    max-width: 480px;
  }
  .blog-all-btn { white-space: nowrap; }
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }
  .blog-featured {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
    height: 100%;
  }
  .blog-featured:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .featured-img-wrap {
    display: block;
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    text-decoration: none;
  }
  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.23,1,0.32,1);
  }
  .blog-featured:hover .featured-img { transform: scale(1.04); }
  .featured-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(10,14,26,0.7) 100%);
  }
  .featured-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: var(--accent);
    color: white;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: var(--font-semibold);
    box-shadow: 0 4px 16px var(--accent-glow);
  }
  .featured-badge .material-symbols-outlined { font-size: 0.9rem; }
  .featured-body {
    padding: 28px 28px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .featured-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .blog-cat {
    font-size: 0.72rem;
    padding: 4px 12px;
  }
  .blog-date, .blog-read {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .blog-date .material-symbols-outlined,
  .blog-read .material-symbols-outlined {
    font-size: 0.9rem;
  }
  .featured-title {
    font-size: 1.3rem;
    line-height: 1.25;
  }
  .featured-title a {
    text-decoration: none;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }
  .featured-title a:hover { color: var(--accent); }
  .featured-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    flex: 1;
  }
  .featured-cta {
    align-self: flex-start;
    font-size: 0.9rem;
    padding: 11px 22px;
    gap: 8px;
  }
  .featured-cta .material-symbols-outlined:last-child {
    margin-left: 2px;
    transition: transform var(--transition-fast);
  }
  .featured-cta:hover .material-symbols-outlined:last-child {
    transform: translateX(4px);
  }
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .blog-card {
    display: grid;
    grid-template-columns: 140px 1fr;
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
    text-decoration: none;
    color: inherit;
  }
  .blog-card:hover {
    transform: translateX(6px);
    box-shadow: var(--shadow-md);
  }
  .blog-card-img-wrap {
    display: block;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
    text-decoration: none;
  }
  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.23,1,0.32,1);
  }
  .blog-card:hover .blog-card-img { transform: scale(1.08); }
  .blog-card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 60%, var(--bg-card) 100%);
  }
  .blog-card-body {
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .blog-cat-sm {
    font-size: 0.68rem;
    padding: 3px 10px;
  }
  .blog-read-sm {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-left: auto;
  }
  .blog-read-sm .material-symbols-outlined { font-size: 0.85rem; }
  .blog-card-title {
    font-size: 0.92rem;
    font-weight: var(--font-semibold);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-title a {
    text-decoration: none;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }
  .blog-card-title a:hover { color: var(--accent); }
  .blog-card-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: auto;
  }
  .blog-date-sm {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .blog-date-sm .material-symbols-outlined { font-size: 0.85rem; }
  .blog-read-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.78rem;
    font-weight: var(--font-semibold);
    color: var(--accent);
    text-decoration: none;
    transition: gap var(--transition-fast);
  }
  .blog-read-link .material-symbols-outlined { font-size: 0.9rem; }
  .blog-read-link:hover { gap: 8px; }
  .blog-card--all {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    color: var(--accent);
    font-weight: var(--font-semibold);
    border: 1.5px dashed var(--border-strong);
    background: transparent;
    cursor: pointer;
    transition: all var(--transition);
  }
  .blog-card--all:hover {
    background: rgba(26,86,219,0.06);
    transform: translateX(6px);
    border-style: solid;
  }
  .all-icon {
    font-size: 1.6rem;
    color: var(--accent);
    flex-shrink: 0;
  }
  .all-text {
    flex: 1;
    font-size: 0.95rem;
  }
  .all-arrow {
    font-size: 1.2rem;
    transition: transform var(--transition-fast);
  }
  .blog-card--all:hover .all-arrow { transform: translateX(6px); }
  @media (max-width: 1024px) {
    .blog-layout { grid-template-columns: 1fr; }
    .blog-featured { max-width: 640px; }
    .featured-img-wrap { aspect-ratio: 2/1; }
  }
  @media (max-width: 640px) {
    .blog-card {
      grid-template-columns: 1fr;
    }
    .blog-card-img-wrap {
      aspect-ratio: 16/7;
    }
    .blog-card-img-overlay {
      background: linear-gradient(to bottom, transparent 60%, var(--bg-card) 100%);
    }
    .blog-header { flex-direction: column; align-items: flex-start; }
    .blog-all-btn { width: 100%; justify-content: center; }
  }
  @media (max-width: 400px) {
    .featured-body { padding: 20px 16px; }
  }
</style>